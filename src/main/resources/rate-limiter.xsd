<?xml version="1.0" encoding="UTF-8"?>
<xsd:schema xmlns="http://www.example.com/schema/rate-limiter"
            xmlns:xsd="http://www.w3.org/2001/XMLSchema"
            targetNamespace="http://www.example.com/schema/rate-limiter"
            elementFormDefault="qualified">

    <xsd:element name="rate-limiter">
        <xsd:complexType>
            <xsd:sequence>
                <xsd:element name="type" type="xsd:string" minOccurs="0" maxOccurs="1"/>
                <xsd:element name="algorithm" type="xsd:string" minOccurs="0" maxOccurs="1"/>
                <xsd:element name="default-config" type="defaultConfigType" minOccurs="0" maxOccurs="1"/>
                <xsd:element name="redis" type="redisConfigType" minOccurs="0" maxOccurs="1"/>
            </xsd:sequence>
        </xsd:complexType>
    </xsd:element>

    <xsd:complexType name="defaultConfigType">
        <xsd:sequence>
            <xsd:element name="permits-per-second" type="xsd:int" minOccurs="0" maxOccurs="1"/>
            <xsd:element name="burst-capacity" type="xsd:int" minOccurs="0" maxOccurs="1"/>
            <xsd:element name="window-size" type="xsd:int" minOccurs="0" maxOccurs="1"/>
            <xsd:element name="window-permits" type="xsd:int" minOccurs="0" maxOccurs="1"/>
        </xsd:sequence>
    </xsd:complexType>

    <xsd:complexType name="redisConfigType">
        <xsd:sequence>
            <xsd:element name="key-prefix" type="xsd:string" minOccurs="0" maxOccurs="1"/>
            <xsd:element name="script-cache" type="xsd:boolean" minOccurs="0" maxOccurs="1"/>
        </xsd:sequence>
    </xsd:complexType>

</xsd:schema>